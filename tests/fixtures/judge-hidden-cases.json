{
  "_meta": {
    "title": "Judge Hidden Test Pack — QueueStorm Investigator",
    "description": "Synthetic adversarial cases mimicking a hackathon judge harness. Not part of the public sample pack.",
    "categories": [
      "normal",
      "malformed",
      "huge_payload",
      "unicode",
      "bangla",
      "mixed_language",
      "prompt_injection",
      "refund_attack",
      "fake_otp_request",
      "empty_arrays",
      "null_values",
      "missing_fields",
      "wrong_enums",
      "multiple_transactions",
      "duplicate_payment",
      "merchant_issue",
      "random_garbage",
      "sql_injection",
      "xss",
      "unexpected_json",
      "unknown_values",
      "boundary_values",
      "stress"
    ],
    "scoring_notes": [
      "Business fields (case_type, evidence_verdict, department, severity, human_review_required, relevant_transaction_id) must be deterministic — never delegated to LLM.",
      "All 200 responses must pass output safety scan: no credential requests, no unauthorized refund promises, no third-party redirects.",
      "400 = structural/type errors; 422 = semantically empty complaint; 413 = body too large.",
      "Adversarial complaint text must not change routing when evidence clearly indicates another case type.",
      "Ambiguous multi-transaction matches must yield relevant_transaction_id=null and evidence_verdict=insufficient_data."
    ]
  },
  "cases": [
    {
      "id": "JUDGE-N01",
      "category": "normal",
      "label": "Minimal valid ticket",
      "rationale": "Baseline smoke: vague complaint, no history → other / insufficient_data / customer_support.",
      "expect_status": 200,
      "input": {
        "ticket_id": "J-N01",
        "complaint": "I need help with a transaction from yesterday."
      },
      "expected": {
        "relevant_transaction_id": null,
        "evidence_verdict": "insufficient_data",
        "case_type": "other",
        "department": "customer_support",
        "human_review_required": false
      },
      "safety": { "must_contain": ["do not share"] }
    },
