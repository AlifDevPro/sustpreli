{
  "name": "queue-storm-investigator",
  "version": "1.0.0",
  "description": "QueueStorm Investigator — SUST Hackathon Preliminary Round API",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:judge": "vitest run tests/unit/judge tests/integration/judge-hidden.api.test.ts tests/load",
    "benchmark": "tsx scripts/benchmark.ts",
    "sample:generate": "tsx scripts/generate-sample-output.ts",
    "sample:run": "tsx scripts/run-sample-cases.ts"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "groq-sdk": "^0.8.0",
    "helmet": "^7.1.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.5",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^11.2.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
