# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
TRUST_PROXY=false

# HTTP
JSON_BODY_LIMIT=1mb
REQUEST_TIMEOUT_MS=28000
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000
CORS_ENABLED=true
CORS_ORIGIN=*
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=600
COMPRESSION_ENABLED=true

# Groq (required in production when analyze-ticket is enabled)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com
GROQ_EXTRACTION_TIMEOUT_MS=8000
GROQ_PROSE_TIMEOUT_MS=12000
GROQ_PROSE_MAX_TOKENS=512
GROQ_MAX_RETRIES=1
GROQ_RETRY_DELAY_MS=500

# Safety
SAFETY_STRICT_MODE=true
